{
  "name": "ipv-cri-ob-api",
  "version": "1.0.0",
  "description": "Open Banking Credential Issuer API",
  "homepage": "https://github.com/govuk-one-login/ipv-cri-ob-api#readme",
  "bugs": {
    "url": "https://github.com/govuk-one-login/ipv-cri-ob-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/govuk-one-login/ipv-cri-ob-api.git"
  },
  "license": "MIT",
  "author": "ipv-cri-lime",
  "type": "module",
  "scripts": {
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:pre-commit": "eslint",
    "test": "vitest run --project unit",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:api": "bddgen --config test/acceptance-tests/playwright.api.config.ts && playwright test --config test/acceptance-tests/playwright.api.config.ts",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/aws-lambda": "8.10.160",
    "@types/node": "25.3.0",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-perfectionist": "5.7.0",
    "jiti": "2.6.1",
    "@playwright/test": "1.59.1",
    "playwright-bdd": "8.5.0",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.0",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "2.31.0",
    "@aws-lambda-powertools/metrics": "2.31.0",
    "@govuk-one-login/cri-logger": "1.0.1",
    "@govuk-one-login/cri-metrics": "1.0.1",
    "esbuild": "0.27.4"
  }
}
